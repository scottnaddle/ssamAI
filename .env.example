# ─────────────────────────────────────────────────────────────
# Project ssamAI — Environment Variables (Phase 1 MVP)
# Copy to `.env` and fill in real values.  NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# ── LLM Providers (LiteLLM upstream) ─────────────────────────
DEEPSEEK_API_KEY=sk-deepseek-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

MINIMAX_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MINIMAX_API_BASE=https://api.minimax.chat/v1
MINIMAX_GROUP_ID=xxxxxxxx

# ── LiteLLM Router ───────────────────────────────────────────
LITELLM_MASTER_KEY=sk-litellm-master-change-me
LITELLM_SALT_KEY=sk-litellm-salt-change-me
LITELLM_PORT=4000

# ── LibreChat ────────────────────────────────────────────────
# Random 16+ char strings — generate with: openssl rand -base64 32
CREDS_KEY=replace-with-32-char-random-string
JWT_SECRET=replace-with-32-char-random-string
JWT_REFRESH_SECRET=replace-with-32-char-random-string
DOMAIN_CLIENT=http://localhost:3090
DOMAIN_SERVER=http://localhost:3090
LIBRECHAT_PORT=3090

# LibreChat → LiteLLM proxy (model-agnostic endpoint)
# The `librechat.yaml` endpoints reference this as the baseURL.
ENDPOINTS=openAI,customEndpoint

# ── MongoDB (LibreChat backing store) ────────────────────────
MONGO_ROOT_USER=ssamai
MONGO_ROOT_PASSWORD=change-me-mongo-pw
MONGO_URI=mongodb://ssamai:change-me-mongo-pw@mongo:27017/LibreChat?authSource=admin
ME_CONFIG_MONGODB_URL=mongodb://ssamai:change-me-mongo-pw@mongo:27017/LibreChat?authSource=admin
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=change-me

# ── Neo4j (Graphiti knowledge graph) ─────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j-password

# ── Graphiti / Persona service ───────────────────────────────
PERSONA_SERVICE_PORT=8100
GRAPHITI_GROUP_ID=default-teacher-group

# ── PPT microservice ─────────────────────────────────────────
PPT_SERVICE_PORT=8200

# ── Web (Next.js) ────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_LIBRECHAT_API=http://localhost:3090/api
NEXT_PUBLIC_PPT_SERVICE_API=http://localhost:8200
NEXT_PUBLIC_PERSONA_SERVICE_API=http://localhost:8100

# ── Redis (community feed cache — Phase 2 prep, optional) ────
REDIS_URL=redis://redis:6379

{
  "name": "ssamai",
  "version": "0.1.0",
  "private": true,
  "description": "Project ssamAI — 한국 교원 특화 AI 에이전트 하네스 플랫폼",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @ssamai/web dev",
    "build": "pnpm --filter @ssamai/web build",
    "lint": "pnpm --filter @ssamai/web lint",
    "typecheck": "pnpm --filter @ssamai/web typecheck",
    "test": "npm run test:python && npm run test:web",
    "test:python": "bash scripts/test-python.sh",
    "test:web": "cd apps/web && npm test",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@ssabrojs/hwpxjs": "^0.4.0"
  }
}
